# 複製此檔為 .env 並填入你的值(.env 不會進版控)
# cp .env.example .env    (Windows: copy .env.example .env)

# === Google Gemini(用 Gemini 當 planner / reviewer 時需要)===
GEMINI_API_KEY=

# === 本機 Ollama(用本機免費模型時;預設值即可,通常不用改)===
OLLAMA_ENDPOINT=http://localhost:11434
# 工具 schema 較多,context 需夠大才不會被截斷;預設 32768
OLLAMA_NUM_CTX=32768
